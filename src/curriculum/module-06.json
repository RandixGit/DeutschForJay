              "tts": true
            },
            {
              "type": "multiple-choice",
              "prompt": "You wake up and say 'Guten ___!'",
              "options": ["Abend", "Nacht", "Morgen", "Nachmittag"],
              "correct": 2,
              "explanation": "Guten Morgen! = Good morning!"
            },
            {
              "type": "multiple-choice",
              "prompt": "Before bed, you say 'Gute ___!'",
              "options": ["Morgen", "Nacht", "Abend", "Tag"],
              "correct": 1,
              "explanation": "Gute Nacht! = Good night!"
