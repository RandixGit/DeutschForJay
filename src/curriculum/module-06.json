            {
              "type": "listen-confirm",
              "german": "Guten Morgen! Guten Tag! Guten Abend! Gute Nacht!",
              "english": "Good morning! Good day! Good evening! Good night!",
              "confirmWord": "abend"
            }
          ]
        },
